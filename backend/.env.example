APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
# For subdirectory deployment (e.g. webspace.ng/oga-tailor), set: APP_BASE_PATH=oga-tailor
APP_BASE_PATH=

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=oga_tailor
DB_USER=root
DB_PASS=
# Hostinger: use credentials from hPanel → Databases → MySQL. DB_HOST=localhost
AUTH_TOKEN_TTL_DAYS=30

WELCOME_EMAIL_FROM=no-reply@ogatailor.app
SUPPORT_EMAIL=support@ogatailor.app

# Cron secret for daily digest (set a random string, e.g. openssl rand -hex 32)
CRON_SECRET=
