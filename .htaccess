DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /oga-tailor/

    RewriteRule ^$ dashboard/ [R=301,L]
    RewriteRule ^index\.html$ dashboard/ [R=301,L]
    RewriteRule ^admin/?$ dashboard/ [R=301,L]

    # Dashboard clean URLs (no .php in browser)
    RewriteRule ^dashboard/?$ dashboard/index.php [L]
    RewriteRule ^dashboard/login/?$ dashboard/login.php [L]
    RewriteRule ^dashboard/logout/?$ dashboard/logout.php [L]
    RewriteRule ^dashboard/forgot-password/?$ dashboard/forgot-password.php [L]
    RewriteRule ^dashboard/reset-password/?$ dashboard/reset-password.php [L]
    RewriteRule ^dashboard/profile/?$ dashboard/profile.php [L]
    RewriteRule ^dashboard/reports/?$ dashboard/reports.php [L]
    RewriteRule ^dashboard/configuration/?$ dashboard/configuration.php [L]
    RewriteRule ^dashboard/admins/?$ dashboard/admins.php [L]
    RewriteRule ^dashboard/audit-log/?$ dashboard/audit-log.php [L]
    RewriteRule ^dashboard/test-paystack/?$ dashboard/test-paystack.php [L]
    RewriteRule ^dashboard/404/?$ dashboard/404.php [L]
    RewriteRule ^dashboard/(?!(login|logout|forgot-password|reset-password|profile|reports|configuration|admins|audit-log|test-paystack|404)(/|$))[a-zA-Z0-9_-]+(/.*)?$ dashboard/404.php [L]

    RewriteRule ^upgrade-callback/?$ upgrade-callback.php [L,QSA]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # API routes -> index.php (backend)
    RewriteRule ^api/ index.php [QSA,L]

    RewriteRule ^ index.php [QSA,L]
</IfModule>
