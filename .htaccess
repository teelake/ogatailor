DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /oga-tailor/

    RewriteRule ^$ dashboard/ [R=301,L]
    RewriteRule ^index\.html$ dashboard/ [R=301,L]
    RewriteRule ^admin/?$ dashboard/ [R=301,L]

    # Dashboard clean URLs (no .php in browser)
    RewriteRule ^dashboard/?$ dashboard/index.php [L]
    RewriteRule ^dashboard/login/?$ dashboard/login.php [L]
    RewriteRule ^dashboard/logout/?$ dashboard/logout.php [L]
    RewriteRule ^dashboard/profile/?$ dashboard/profile.php [L]
    RewriteRule ^dashboard/reports/?$ dashboard/reports.php [L]
    RewriteRule ^dashboard/configuration/?$ dashboard/configuration.php [L]
    RewriteRule ^dashboard/admins/?$ dashboard/admins.php [L]

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^ index.php [QSA,L]
</IfModule>
